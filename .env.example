# База данных (PostgreSQL в Docker)
POSTGRES_DB=wastecontrol
POSTGRES_USER=wastecontrol_user
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://wastecontrol_user:change_me_strong_password@postgres:5432/wastecontrol

# JWT
SECRET_KEY=change_me_very_long_random_string_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis
REDIS_URL=redis://redis:6379/0

# Telegram (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Sentry (опционально — мониторинг ошибок, https://sentry.io)
SENTRY_DSN=
APP_ENV=production

# Google Sheets — через файл google_credentials.json (не нужно здесь)
# Скопируй backend/google_credentials.json на сервер вручную
